# Program to check if a number is palindrome

num = int(input("Enter a number: "))

original = num  # Store original number
reverse = 0

# Reverse the number
while num > 0:
    digit = num % 10
    reverse = reverse * 10 + digit
    num = num // 10

# Check if original and reverse are same
if original == reverse:
    print("Palindrome")
else:
    print("Not Palindrome")
