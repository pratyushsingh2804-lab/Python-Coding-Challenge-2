# Program to convert string to uppercase without using upper()

text = input("Enter a string: ")

result = ""  # Store converted string

# Loop through each character
for ch in text:
    # Check if character is lowercase (ASCII range)
    if 'a' <= ch <= 'z':
        # Convert to uppercase using ASCII value
        result += chr(ord(ch) - 32)
    else:
        result += ch  # Keep as it is if not lowercase

# Print result
print("Uppercase string:", result)
